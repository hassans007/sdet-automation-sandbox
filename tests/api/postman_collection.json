{
  "info": {
    "name": "SDET Sandbox API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Admin Reset",
      "request": {
        "method": "POST",
        "header": [{ "key": "x-reset-token", "value": "{{resetToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/admin/reset", "host": ["{{baseUrl}}"], "path": ["api", "admin", "reset"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('reset ok', () => pm.response.code === 200);"
            ]
          }
        }
      ]
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "content-type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"sdet@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', () => pm.response.code === 200);",
              "const json = pm.response.json();",
              "pm.environment.set('token', json.token);",
              "pm.test('token present', () => !!json.token);",
              "pm.test('schema: token is string', () => typeof json.token === 'string');"
            ]
          }
        }
      ]
    },
    {
      "name": "List Todos",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": { "raw": "{{baseUrl}}/api/todos", "host": ["{{baseUrl}}"], "path": ["api", "todos"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', () => pm.response.code === 200);",
              "const todos = pm.response.json();",
              "pm.test('returns array', () => Array.isArray(todos));",
              "pm.test('todo has required fields', () => {",
              "  if (todos.length === 0) return;",
              "  const t = todos[0];",
              "  pm.expect(t).to.have.property('id');",
              "  pm.expect(t).to.have.property('title');",
              "  pm.expect(t).to.have.property('completed');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}